# Version control
.git
.svn
.hg

# Python bytecode and caches
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments (deps live in /opt/venv inside the image)
.venv/
venv/
env/

# UV cache
.uv/

# Editor artefacts
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# Build / distribution artefacts
build/
dist/
*.egg-info/

# Large model weight files (downloaded at runtime, not baked into the image)
gpt2/
*.pth
*.ckpt
*.bin
*.safetensors

# Jupyter notebook checkpoints
.ipynb_checkpoints/

# MLflow database (runtime artefact, not needed at build time)
mlflow/*.db

# PDF artefacts generated by notebooks
*.pdf

# Environment files with secrets
.env
*.env.local

# Project name
PROJECT_NAME=llms-project

# Environment used in building API: development (true) or production (false)
DEVELOPMENT=true

# Environment used in building API: with gpu support (true) or without gpu support (false)
USE_GPUS=true

# Compose file to use   
COMPOSE_FILE=docker-compose.dev.gpu.yaml

# Worker service to use
WORKER_SERVICE=worker-service-gpu

# API secret key for openai
OPENAI_API_KEY=<INSERT SECRET KEY HERE>

# Fastapi service
APP_PORT=8000

# RabbitMQ service
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_HOST=broker-service
RABBITMQ_PORT=5672
RABBITMQ_PORT_UI=15672
BROKER_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_PORT}/

# MongoDB service
MONGODB_PORT=27017

# Chroma vector database service
CHROMA_PORT=8878

# Jupyter lab server
JUPYTER_EXTERNAL_PORT=8888

# MLflow tracking server
MLFLOW_PORT=5000
MLFLOW_TRACKING_URI=sqlite:////mlflow_app/database.db

# Project name
PROJECT_NAME=llmsplay

# Set to true to use the GPU compose file and gpu PyTorch index; false for CPU
# The Makefile derives COMPOSE_FILE automatically from this value
USE_GPU=true

# Worker service name (used by make debug-worker and make jupyter)
WORKER_SERVICE=worker-service

# OpenAI API key for API calls and agent experiments
OPENAI_API_KEY=<INSERT SECRET KEY HERE>

# JupyterLab port (accessible at http://localhost:JUPYTER_EXTERNAL_PORT)
JUPYTER_EXTERNAL_PORT=8888

# MLflow tracking server port (accessible at http://localhost:MLFLOW_PORT)
MLFLOW_PORT=5000

# MLflow backend store: SQLite database persisted inside the project directory
MLFLOW_TRACKING_URI=sqlite:////llm_app/mlflow/database.db

# Ollama server port (accessible at http://localhost:OLLAMA_PORT from the host)
OLLAMA_PORT=11434
